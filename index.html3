  runAIEngine();

  document.getElementById('headerStatus').innerHTML = '<span class="badge" style="background:var(--ys);color:var(--yellow)"><span class="status-dot" style="background:var(--yellow)"></span> Demo Data</span>';
  document.getElementById('headerEnv').textContent = 'UPTIVE Demo (static data)';

  document.querySelector('[data-tab="jobs"]').click();
}

// ═══ JOB DETAIL MODAL ═══
function closeJobDetail() {
  document.getElementById('jobDetailOverlay').style.display = 'none';
}

async function showJobDetail(jobNum) {
  const overlay = document.getElementById('jobDetailOverlay');
  const content = document.getElementById('jdContent');

  // Find job in loaded data
  const job = LIVE_JOBS.find(j => j.id === jobNum);
  const wfJob = WF_JOBS.find(j => j.id === jobNum);

  if (!job) { alert('Job not found'); return; }

  document.getElementById('jdTitle').textContent = `Job ${jobNum} — ${job.part}`;
  document.getElementById('jdSubtitle').textContent = job.raw?.CommentText || '';
  content.innerHTML = '<div style="text-align:center;padding:30px"><div class="spinner"></div><div style="margin-top:8px;color:var(--tmu)">Loading job details...</div></div>';
  overlay.style.display = 'block';

  try {
    // Fetch full job details
    const jobData = await kineticAPI('GET', `Erp.BO.JobEntrySvc/JobEntries?$filter=JobNum eq '${jobNum}'&$top=1`);
    const fullJob = jobData.value?.[0] || job.raw || {};

    // Determine MTS vs MTO
    const jobType = fullJob.JobType || '';
    const isMTO = jobType === 'MFG-MTO' || jobType === 'MTO' || (fullJob.QuoteNum && fullJob.QuoteNum > 0);
    const isMTS = !isMTO;
    const typeLabel = isMTO ? 'Make to Order (MTO)' : 'Make to Stock (MTS)';
    const typeColor = isMTO ? 'var(--os);color:var(--orange)' : 'var(--ts);color:var(--teal)';

    // Dates
    const reqDue = (fullJob.ReqDueDate || '').split('T')[0];
    const schedStart = (fullJob.StartDate || '').split('T')[0];
    const schedDue = (fullJob.DueDate || '').split('T')[0];
    const dl = reqDue ? Math.ceil((new Date(reqDue) - new Date()) / 86400000) : 99;
    const dlColor = dl <= 3 ? 'var(--red)' : dl <= 7 ? 'var(--orange)' : dl <= 14 ? 'var(--yellow)' : 'var(--green)';
    const priLabel = PRI_LABELS[fullJob.SchedCode] || fullJob.SchedCode || 'Normal';

    // Operations from workflow data
    const ops = wfJob?.operations || [];
    let totalEstHrs = 0, totalActHrs = 0, totalEstCost = 0, totalActCost = 0;
    const opsRows = ops.map(op => {
      const estH = (op.EstProdHours || 0) + (op.EstSetHours || 0);
      const actH = (op.ActProdHours || 0) + (op.ActSetupHours || 0);
      const estC = op.EstLaborCost || op.EstUnitCost || 0;
      const actC = (op.ActLabCost || 0) + (op.ActBurCost || 0);
      totalEstHrs += estH; totalActHrs += actH; totalEstCost += estC; totalActCost += actC;
      const status = op.OpComplete ? '✓ Complete' : '○ Pending';
      const statusColor = op.OpComplete ? 'var(--green)' : 'var(--tmu)';
      const resGrp = op.PrimaryResourceGrpID || op.ResourceGrpID || '';
      return `<tr>
        <td class="mono" style="font-size:11px">${op.OprSeq}</td>
        <td style="font-weight:600">${op.OpCode || ''}</td>
        <td style="font-size:11px;color:var(--tmu)">${resGrp}</td>
        <td class="mono">${estH.toFixed(1)}h</td>
        <td class="mono">${actH > 0 ? actH.toFixed(1) + 'h' : '—'}</td>
        <td class="mono">$${estC.toFixed(0)}</td>
        <td class="mono">${actC > 0 ? '$' + actC.toFixed(0) : '—'}</td>
        <td style="color:${statusColor};font-size:11px;font-weight:600">${status}</td>
      </tr>`;
    }).join('');

    // Material costs
    const estMatCost = fullJob.EstSubCost || 0;
    const actMatCost = fullJob.ActSubCost || 0;

    content.innerHTML = `
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin-bottom:16px">
        <div style="padding:10px;background:var(--sa);border-radius:6px;text-align:center">
          <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase">Type</div>
          <div><span class="badge" style="background:${typeColor};font-size:11px">${typeLabel}</span></div>
        </div>
        <div style="padding:10px;background:var(--sa);border-radius:6px;text-align:center">
          <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase">Priority</div>
          <div style="font-size:14px;font-weight:700">${priLabel}</div>
        </div>
        <div style="padding:10px;background:var(--sa);border-radius:6px;text-align:center">
          <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase">Due Date</div>
          <div class="mono" style="font-size:14px;font-weight:700;color:${dlColor}">${reqDue || '—'}</div>
          <div style="font-size:10px;color:${dlColor}">${dl}d remaining</div>
        </div>
        <div style="padding:10px;background:var(--sa);border-radius:6px;text-align:center">
          <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase">Qty</div>
          <div style="font-size:14px;font-weight:700">${fullJob.ProdQty || job.qty}</div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px">
        <div style="padding:10px;background:var(--sa);border-radius:6px">
          <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase;margin-bottom:4px">Job Details</div>
          <div style="font-size:12px;line-height:1.8">
            <div><span style="color:var(--tmu);width:100px;display:inline-block">Part:</span> <b>${fullJob.PartNum || ''}</b> Rev ${fullJob.RevisionNum || '—'}</div>
            <div><span style="color:var(--tmu);width:100px;display:inline-block">Description:</span> ${fullJob.PartDescription || ''}</div>
            <div><span style="color:var(--tmu);width:100px;display:inline-block">Sched Start:</span> <span class="mono">${schedStart && schedStart !== '0001-01-01' ? schedStart : 'Not scheduled'}</span></div>
            <div><span style="color:var(--tmu);width:100px;display:inline-block">Sched Due:</span> <span class="mono">${schedDue && schedDue !== '0001-01-01' ? schedDue : 'Not scheduled'}</span></div>
            ${fullJob.DrawNum ? `<div><span style="color:var(--tmu);width:100px;display:inline-block">Drawing:</span> ${fullJob.DrawNum}</div>` : ''}
          </div>
        </div>
        <div style="padding:10px;background:var(--sa);border-radius:6px">
          <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase;margin-bottom:4px">${isMTO ? 'Order Info' : 'Stock Info'}</div>
          <div style="font-size:12px;line-height:1.8">
            ${isMTO && fullJob.QuoteNum ? `<div><span style="color:var(--tmu)">Quote:</span> <b>${fullJob.QuoteNum}-${fullJob.QuoteLine || 0}</b></div>` : ''}
            <div><span style="color:var(--tmu)">Job Type:</span> ${fullJob.JobType || 'Manufacturing'}</div>
            <div><span style="color:var(--tmu)">Created:</span> <span class="mono">${(fullJob.CreateDate||'').split('T')[0] || '—'}</span></div>
            <div><span style="color:var(--tmu)">Created By:</span> ${fullJob.CreatedBy || '—'}</div>
            <div><span style="color:var(--tmu)">Engineered:</span> ${fullJob.JobEngineered ? '✓ Yes' : '○ No'}</div>
            <div><span style="color:var(--tmu)">Released:</span> ${fullJob.JobReleased ? '✓ Yes' : '○ No'}</div>
          </div>
        </div>
      </div>

      <div style="margin-bottom:16px">
        <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--tmu);margin-bottom:8px">Operations — Estimated vs Actual</div>
        <div style="overflow-x:auto">
          <table style="width:100%"><thead><tr>
            <th style="width:40px">Seq</th><th>Op Code</th><th>Resource</th><th>Est Hrs</th><th>Act Hrs</th><th>Est Cost</th><th>Act Cost</th><th>Status</th>
          </tr></thead><tbody>${opsRows || '<tr><td colspan="8" style="text-align:center;color:var(--tmu)">No operations loaded</td></tr>'}</tbody>
          <tfoot><tr style="font-weight:700;border-top:2px solid var(--bd)">
            <td colspan="3" style="padding:8px 12px">Totals</td>
            <td style="padding:8px 12px" class="mono">${totalEstHrs.toFixed(1)}h</td>
            <td style="padding:8px 12px" class="mono">${totalActHrs > 0 ? totalActHrs.toFixed(1) + 'h' : '—'}</td>
            <td style="padding:8px 12px" class="mono">$${totalEstCost.toFixed(0)}</td>
            <td style="padding:8px 12px" class="mono">${totalActCost > 0 ? '$' + totalActCost.toFixed(0) : '—'}</td>
            <td></td>
          </tr></tfoot></table>
        </div>
      </div>

      <div style="display:flex;gap:8px;margin-top:16px">
        <button class="btn btn-teal" onclick="closeJobDetail();quickAction('${jobNum}','priorityHigh')">⬆ Expedite</button>
        <button class="btn btn-outline" onclick="closeJobDetail();quickAction('${jobNum}','scheduleForward')">▶ Schedule Forward</button>
        <button class="btn btn-outline" onclick="closeJobDetail();quickAction('${jobNum}','hold')">⏸ Hold</button>
      </div>
    `;
  } catch (err) {
    content.innerHTML = `<div style="color:var(--red);padding:20px">Error loading job details: ${err.message}</div>`;
  }
}
</script>
</body>
</html>
