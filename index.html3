<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kinetic Scheduler — Live Connection</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--teal:#00897B;--td:#00695C;--tl:#e0f2f1;--ts:rgba(0,137,123,.08);--bg:#f0f2f5;--sf:#fff;--sa:#f8f9fb;--bd:#e0e4ea;--bl:#eef0f4;--tx:#1a202c;--tm:#4a5568;--tmu:#718096;--tdi:#a0aec0;--red:#e53e3e;--rs:rgba(229,62,62,.08);--green:#2f855a;--gs:rgba(47,133,90,.08);--yellow:#d69e2e;--ys:rgba(214,158,46,.08);--orange:#dd6b20;--os:rgba(221,107,32,.08);--purple:#805ad5;--ps:rgba(128,90,213,.08)}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'IBM Plex Sans',sans-serif;background:var(--bg);color:var(--tx);font-size:13px;line-height:1.5}
.header{background:var(--sf);border-bottom:1px solid var(--bd);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:56px;position:sticky;top:0;z-index:100}
.logo{width:34px;height:34px;border-radius:6px;background:linear-gradient(135deg,var(--teal),var(--td));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:16px}
.badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:4px;font-size:11px;font-weight:600;white-space:nowrap}
.tabs{display:flex;gap:0;background:var(--sf);border-bottom:2px solid var(--bd);padding:0 24px;overflow-x:auto}
.tab{padding:11px 16px;font-size:12px;font-weight:600;color:var(--tmu);cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s;white-space:nowrap}
.tab:hover{color:var(--tx);background:var(--sa)}.tab.active{color:var(--teal);border-bottom-color:var(--teal)}
.content{padding:20px 24px;max-width:1260px;margin:0 auto}
.tc{display:none}.tc.active{display:block;animation:fi .2s ease}
@keyframes fi{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
.card{background:var(--sf);border:1px solid var(--bd);border-radius:6px;padding:16px;margin-bottom:12px}
table{width:100%;border-collapse:separate;border-spacing:0;font-size:12.5px}
thead th{padding:9px 12px;text-align:left;font-weight:600;font-size:10.5px;text-transform:uppercase;letter-spacing:.6px;color:var(--tmu);background:var(--sa);border-bottom:1px solid var(--bd)}
tbody td{padding:9px 12px;border-bottom:1px solid var(--bl);vertical-align:middle}
tbody tr:hover{background:var(--ts)}
.mono{font-family:'IBM Plex Mono',monospace;font-size:11.5px}
.sh{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--tmu);margin:20px 0 10px;display:flex;align-items:center;gap:8px}
.sh::after{content:'';flex:1;height:1px;background:var(--bd)}
input[type=text],input[type=password]{width:100%;padding:8px 12px;border:1px solid var(--bd);border-radius:4px;font-size:13px;font-family:'IBM Plex Sans',sans-serif;background:var(--sf);color:var(--tx)}
input:focus{outline:none;border-color:var(--teal);box-shadow:0 0 0 2px var(--ts)}
.btn{padding:8px 20px;border-radius:4px;border:none;font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;font-family:'IBM Plex Sans',sans-serif}
.btn-teal{background:var(--teal);color:#fff}.btn-teal:hover{background:var(--td)}
.btn-outline{background:var(--sf);color:var(--teal);border:1px solid var(--teal)}.btn-outline:hover{background:var(--tl)}
.btn-red{background:var(--red);color:#fff}
.btn:disabled{opacity:.5;cursor:not-allowed}
.spinner{display:inline-block;width:16px;height:16px;border:2px solid var(--bd);border-top-color:var(--teal);border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle}
.status-dot{width:8px;height:8px;border-radius:50%;display:inline-block}
.log-entry{padding:6px 10px;border-radius:4px;font-size:11px;font-family:'IBM Plex Mono',monospace;margin-bottom:4px;line-height:1.5;word-break:break-all}
.log-ok{background:var(--gs);color:var(--green)}
.log-err{background:var(--rs);color:var(--red)}
.log-info{background:var(--sa);color:var(--tmu)}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:20px}
.stat-card{border-left-width:3px;border-left-style:solid}
.rec-card{border-radius:6px;padding:14px;margin-bottom:8px;border:1px solid var(--bd);background:var(--sf);border-left:4px solid var(--yellow)}
.rec-card.critical{border-left-color:var(--red)}.rec-card.high{border-left-color:var(--orange)}.rec-card.info{border-left-color:var(--teal)}
</style>
</head>
<body>
<div class="header">
  <div style="display:flex;align-items:center;gap:12px">
    <div class="logo">K</div>
    <div>
      <div style="font-size:15px;font-weight:700">Epicor Kinetic — AI Scheduling Dashboard</div>
      <div style="font-size:11px;color:var(--tmu)">Live Kinetic Connection — <span id="headerEnv" style="color:var(--teal);font-weight:600">Not Connected</span></div>
    </div>
  </div>
  <div id="headerStatus" style="display:flex;gap:6px;align-items:center">
    <span class="badge" style="background:var(--rs);color:var(--red)"><span class="status-dot" style="background:var(--red)"></span> Disconnected</span>
  </div>
</div>

<div class="tabs">
  <button class="tab active" data-tab="connect">⚡ Connect to Kinetic</button>
  <button class="tab" data-tab="jobs">◎ Live Jobs</button>
  <button class="tab" data-tab="workflow">⊞ Job Workflow</button>
  <button class="tab" data-tab="resources">⬢ Resources</button>
  <button class="tab" data-tab="recs">✦ AI Recommendations</button>
  <button class="tab" data-tab="actions">⟲ Actions</button>
  <button class="tab" data-tab="log">▤ API Log</button>
</div>

<div class="content">

<!-- ═══ CONNECT TAB ═══ -->
<div class="tc active" id="tab-connect">
  <div class="card" style="border-left:3px solid var(--teal);max-width:600px">
    <div style="font-size:15px;font-weight:700;margin-bottom:4px">Connect to Your Kinetic Instance</div>
    <div style="font-size:12px;color:var(--tmu);margin-bottom:16px">Enter your connection details below. The dashboard will call the Kinetic REST API directly to pull scheduling data and push actions.</div>

    <div style="margin-bottom:12px">
      <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">Server URL</label>
      <input type="text" id="cfgServer" value="https://seiajr8af3.developer.epicor.com/server" placeholder="https://yourserver.epicor.com/server">
    </div>
    <div style="margin-bottom:12px">
      <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">Company ID</label>
      <input type="text" id="cfgCompany" placeholder="EPIC06 or SALESUSMFG — from Company dropdown">
    </div>
    <div style="margin-bottom:12px">
      <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">Username</label>
      <input type="text" id="cfgUser" placeholder="Josh.Roberts@epicor.com">
    </div>
    <div style="margin-bottom:12px">
      <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">Password</label>
      <input type="password" id="cfgPass" placeholder="Your Kinetic password">
    </div>
    <div style="margin-bottom:16px">
      <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">API Key</label>
      <input type="text" id="cfgApiKey" placeholder="From API Key Maintenance">
    </div>

    <div style="display:flex;gap:8px;align-items:center">
      <button class="btn btn-teal" id="btnConnect" onclick="testConnection()">Test Connection</button>
      <button class="btn btn-outline" onclick="loadAllData()" id="btnLoad">Pull All Data</button>
      <span id="connStatus" style="font-size:12px;color:var(--tmu)"></span>
    </div>
  </div>

  <div id="connResult"></div>

  <div class="card" style="max-width:600px;margin-top:8px;background:var(--sa)">
    <div style="font-size:12px;font-weight:600;margin-bottom:6px">How this works</div>
    <div style="font-size:12px;color:var(--tmu);line-height:1.7">
      The dashboard calls your Kinetic REST API through Automation Studio or directly via the REST endpoint. It reads Jobs, Resources, Shop Load, and Production Calendars, runs the AI recommendation engine client-side, and displays results. Actions (priority changes, resource reassignment, holds) push back to Kinetic through the same API.
    </div>
  </div>
</div>

<!-- ═══ JOBS TAB ═══ -->
<div class="tc" id="tab-jobs">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:8px">
    <div style="font-size:14px;font-weight:700">Live Jobs from Kinetic</div>
    <div style="display:flex;gap:6px;align-items:center">
      <input type="text" id="jobFilter" placeholder="Filter by job, part, or status..." oninput="filterJobs()" style="width:220px;padding:5px 10px;font-size:12px">
      <button class="btn btn-teal" id="btnJobScope" onclick="toggleJobScope()" style="font-size:11px;padding:5px 14px">Showing: All 2026 Jobs</button>
      <button class="btn btn-outline" onclick="fetchJobs()" style="font-size:11px;padding:5px 14px">↻ Refresh</button>
      <span id="jobCount" class="badge" style="background:var(--sa);color:var(--tmu);border:1px solid var(--bd)">0 jobs</span>
    </div>
  </div>
  <div style="font-size:11px;color:var(--tmu);margin-bottom:10px">Click any job row to select it for actions. Use the inline buttons for quick actions.</div>
  <div id="jobsLoading" style="display:none;text-align:center;padding:40px"><div class="spinner"></div><div style="margin-top:8px;color:var(--tmu)">Pulling jobs from Kinetic...</div></div>
  <div id="jobsEmpty" class="card" style="text-align:center;color:var(--tmu);padding:40px;display:none">No jobs found. Connect to Kinetic first, or create jobs in Job Entry.</div>
  <div class="card" style="padding:0;overflow-x:auto"><table><thead><tr><th>Job</th><th>Part</th><th>Qty</th><th>Due Date</th><th>Priority</th><th>Status</th><th>Actions</th></tr></thead><tbody id="jobsTable"></tbody></table></div>
</div>

<!-- ═══ JOB WORKFLOW TAB ═══ -->
<div class="tc" id="tab-workflow">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:8px">
    <div style="font-size:14px;font-weight:700">Job Workflow — Operation Progress</div>
    <div style="display:flex;gap:6px;align-items:center">
      <input type="text" id="wfFilter" placeholder="Filter by job, part, customer..." oninput="activeWfFilter='';renderWorkflow()" style="width:220px;padding:5px 10px;font-size:12px">
      <button class="btn btn-outline" onclick="fetchWorkflow()" style="font-size:11px;padding:5px 14px">↻ Refresh</button>
      <span id="wfCount" class="badge" style="background:var(--sa);color:var(--tmu);border:1px solid var(--bd)">0 jobs</span>
    </div>
  </div>
  <div style="display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap">
    <button class="btn btn-teal" onclick="setWfFilter('')" style="font-size:10px;padding:4px 10px" id="wfBtnAll">All Jobs</button>
    <button class="btn btn-outline" onclick="setWfFilter('__critical')" style="font-size:10px;padding:4px 10px">Due ≤ 7 Days</button>
    <button class="btn btn-outline" onclick="setWfFilter('__late')" style="font-size:10px;padding:4px 10px">Estimated Late</button>
    <button class="btn btn-outline" onclick="setWfFilter('__inprogress')" style="font-size:10px;padding:4px 10px">In Progress</button>
    <button class="btn btn-outline" onclick="setWfFilter('UPT')" style="font-size:10px;padding:4px 10px">Uptive Jobs</button>
  </div>
  <div style="display:flex;gap:12px;margin-bottom:12px;font-size:11px;color:var(--tmu);flex-wrap:wrap">
    <span style="display:flex;align-items:center;gap:4px"><span style="width:12px;height:12px;border-radius:3px;background:var(--green);display:inline-block"></span> Complete</span>
    <span style="display:flex;align-items:center;gap:4px"><span style="width:12px;height:12px;border-radius:3px;background:var(--teal);display:inline-block;border:2px solid var(--td)"></span> In Progress</span>
    <span style="display:flex;align-items:center;gap:4px"><span style="width:12px;height:12px;border-radius:3px;background:var(--bd);display:inline-block"></span> Pending</span>
    <span style="display:flex;align-items:center;gap:4px"><span style="width:12px;height:12px;border-radius:3px;background:var(--red);display:inline-block"></span> Over Time</span>
  </div>
  <div id="wfLoading" style="display:none;text-align:center;padding:40px"><div class="spinner"></div><div style="margin-top:8px;color:var(--tmu)">Loading job operations...</div></div>
  <div id="wfGrid"></div>
</div>

<!-- ═══ RESOURCES TAB ═══ -->
<div class="tc" id="tab-resources">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:8px">
    <div style="font-size:14px;font-weight:700">Work Center Load — Jobs by Resource</div>
    <div style="display:flex;gap:6px;align-items:center">
      <button class="btn btn-teal" id="btnResFilter" onclick="toggleResFilter()" style="font-size:11px;padding:5px 14px">Showing: Scheduled Only</button>
      <span id="resJobCount" class="badge" style="background:var(--sa);color:var(--tmu);border:1px solid var(--bd)">0 active ops</span>
      <button class="btn btn-outline" onclick="fetchResourceLoad()" style="font-size:11px;padding:5px 14px">↻ Refresh</button>
    </div>
  </div>
  <div id="resLoading" style="display:none;text-align:center;padding:40px"><div class="spinner"></div><div style="margin-top:8px;color:var(--tmu)">Pulling resources and job operations...</div></div>
  <div id="resGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:12px"></div>
</div>

<!-- ═══ AI RECOMMENDATIONS TAB ═══ -->
<div class="tc" id="tab-recs">
  <div class="card" style="border-left:3px solid var(--purple);margin-bottom:16px">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px">
      <div style="font-size:15px;font-weight:700">AI Recommendations</div>
      <span id="recCount" class="badge" style="background:var(--ps);color:var(--purple)">0 recommendations</span>
    </div>
    <div style="font-size:12px;color:var(--tmu)">Generated from your live Kinetic data. Each recommendation includes a one-click action to push changes back.</div>
  </div>
  <div id="recsLoading" style="display:none;text-align:center;padding:40px"><div class="spinner"></div><div style="margin-top:8px;color:var(--tmu)">Analyzing scheduling data...</div></div>
  <div id="recsList" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px"></div>
</div>

<!-- ═══ ACTIONS TAB ═══ -->
<div class="tc" id="tab-actions">
  <div class="card" style="border-left:3px solid var(--orange)">
    <div style="font-size:15px;font-weight:700;margin-bottom:4px">Push Actions to Kinetic</div>
    <div style="font-size:12px;color:var(--tmu);margin-bottom:16px">Each action calls the Kinetic REST API to modify live data. Every call is logged in the API Log tab.</div>

    <div style="margin-bottom:16px">
      <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">Job Number</label>
      <input type="text" id="actJob" placeholder="Enter your Job Number from Kinetic" style="max-width:300px">
    </div>
  </div>

  <div class="sh">Scheduling Actions</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:10px;margin-bottom:16px">
    <div class="card" style="border-top:3px solid var(--teal);cursor:pointer" onclick="runAction('scheduleForward')">
      <div style="font-size:18px;margin-bottom:4px">▶</div>
      <div style="font-size:13px;font-weight:700;margin-bottom:3px">Schedule Forward</div>
      <div style="font-size:11px;color:var(--tmu);line-height:1.5;margin-bottom:6px">Forward schedule from the Start Date. The engine places scheduling blocks into the earliest available capacity slots moving forward.</div>
      <div style="font-size:10px;font-family:'IBM Plex Mono',monospace;color:var(--td);background:var(--sa);padding:4px 8px;border-radius:3px">POST ScheduleEngineSvc → Direction: Start</div>
    </div>
    <div class="card" style="border-top:3px solid var(--purple);cursor:pointer" onclick="runAction('scheduleBackward')">
      <div style="font-size:18px;margin-bottom:4px">◀</div>
      <div style="font-size:13px;font-weight:700;margin-bottom:3px">Schedule Backward</div>
      <div style="font-size:11px;color:var(--tmu);line-height:1.5;margin-bottom:6px">Backward schedule from the Due Date. Scheduling blocks placed so the last operation finishes by the required date.</div>
      <div style="font-size:10px;font-family:'IBM Plex Mono',monospace;color:var(--td);background:var(--sa);padding:4px 8px;border-radius:3px">POST ScheduleEngineSvc → Direction: End</div>
    </div>
    <div class="card" style="border-top:3px solid var(--red);cursor:pointer" onclick="runAction('unschedule')">
      <div style="font-size:18px;margin-bottom:4px">✕</div>
      <div style="font-size:13px;font-weight:700;margin-bottom:3px">Remove from Schedule</div>
      <div style="font-size:11px;color:var(--tmu);line-height:1.5;margin-bottom:6px">Clears all scheduling blocks from resources. Job stays released but unscheduled. Frees capacity immediately.</div>
      <div style="font-size:10px;font-family:'IBM Plex Mono',monospace;color:var(--td);background:var(--sa);padding:4px 8px;border-radius:3px">PATCH JobEntry → JobScheduled: false</div>
    </div>
  </div>

  <div class="sh">Change Priority</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:8px;margin-bottom:16px">
    <div class="card" style="border-top:3px solid var(--red);cursor:pointer;padding:12px" onclick="runAction('priorityImmediate')">
      <div style="font-size:13px;font-weight:700;color:var(--red)">Immediate</div>
      <div style="font-size:10px;color:var(--tmu);margin-top:2px">Auto-triggers Forward Schedule</div>
    </div>
    <div class="card" style="border-top:3px solid var(--orange);cursor:pointer;padding:12px" onclick="runAction('priorityVeryHigh')">
      <div style="font-size:13px;font-weight:700;color:var(--orange)">Very High</div>
      <div style="font-size:10px;color:var(--tmu);margin-top:2px">Top of the queue</div>
    </div>
    <div class="card" style="border-top:3px solid var(--yellow);cursor:pointer;padding:12px" onclick="runAction('priorityHigh')">
      <div style="font-size:13px;font-weight:700;color:var(--yellow)">High</div>
      <div style="font-size:10px;color:var(--tmu);margin-top:2px">Elevated priority</div>
    </div>
    <div class="card" style="border-top:3px solid var(--teal);cursor:pointer;padding:12px" onclick="runAction('priorityNormal')">
      <div style="font-size:13px;font-weight:700;color:var(--teal)">Normal</div>
      <div style="font-size:10px;color:var(--tmu);margin-top:2px">Standard scheduling</div>
    </div>
    <div class="card" style="border-top:3px solid var(--tdi);cursor:pointer;padding:12px" onclick="runAction('priorityLow')">
      <div style="font-size:13px;font-weight:700;color:var(--tdi)">Low</div>
      <div style="font-size:10px;color:var(--tmu);margin-top:2px">Fill-in work</div>
    </div>
  </div>

  <div class="sh">Job Status</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:10px;margin-bottom:16px">
    <div class="card" style="border-top:3px solid var(--yellow);cursor:pointer" onclick="runAction('hold')">
      <div style="font-size:18px;margin-bottom:4px">⏸</div>
      <div style="font-size:13px;font-weight:700;margin-bottom:3px">Put Job on Hold</div>
      <div style="font-size:11px;color:var(--tmu);line-height:1.5">Scheduling blocks released. Capacity freed. Materials stay allocated.</div>
    </div>
    <div class="card" style="border-top:3px solid var(--green);cursor:pointer" onclick="runAction('release')">
      <div style="font-size:18px;margin-bottom:4px">▶</div>
      <div style="font-size:13px;font-weight:700;margin-bottom:3px">Release from Hold</div>
      <div style="font-size:11px;color:var(--tmu);line-height:1.5">Job becomes eligible for scheduling. Run Schedule Forward or Backward after.</div>
    </div>
  </div>

  <div id="actionResult" style="margin-top:4px"></div>
</div>

<!-- ═══ LOG TAB ═══ -->
<div class="tc" id="tab-log">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
    <div style="font-size:14px;font-weight:700">API Call Log</div>
    <button class="btn btn-outline" onclick="document.getElementById('logEntries').innerHTML=''" style="font-size:11px;padding:5px 14px">Clear</button>
  </div>
  <div class="card" style="padding:12px;max-height:500px;overflow-y:auto"><div id="logEntries"></div></div>
</div>

</div>

<!-- ═══ JOB DETAIL MODAL ═══ -->
<div id="jobDetailOverlay" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:200;overflow-y:auto;padding:40px 20px" onclick="if(event.target===this)closeJobDetail()">
  <div style="max-width:800px;margin:0 auto;background:var(--sf);border-radius:8px;border:1px solid var(--bd);overflow:hidden" onclick="event.stopPropagation()">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;background:var(--teal);color:#fff">
      <div>
        <div id="jdTitle" style="font-size:18px;font-weight:700"></div>
        <div id="jdSubtitle" style="font-size:12px;opacity:.8"></div>
      </div>
      <button onclick="closeJobDetail()" style="background:none;border:none;color:#fff;font-size:24px;cursor:pointer;padding:0 8px">×</button>
    </div>
    <div id="jdContent" style="padding:20px"></div>
  </div>
</div>

<script>
// ═══ STATE ═══
let CONFIG = { server:'', company:'', user:'', pass:'', apiKey:'' };
let CONNECTED = false;
let LIVE_JOBS = [];
let LIVE_RESOURCES = [];

// ═══ TABS ═══
document.querySelectorAll('.tab').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));document.querySelectorAll('.tc').forEach(t=>t.classList.remove('active'));b.classList.add('active');document.getElementById('tab-'+b.dataset.tab).classList.add('active')})});

// ═══ LOGGING ═══
function log(type, method, url, detail) {
  const el = document.getElementById('logEntries');
  const time = new Date().toLocaleTimeString();
  const cls = type === 'ok' ? 'log-ok' : type === 'err' ? 'log-err' : 'log-info';
  const icon = type === 'ok' ? '✓' : type === 'err' ? '✗' : '→';
  el.insertAdjacentHTML('afterbegin',
    `<div class="log-entry ${cls}">${icon} ${time} — ${method} ${url}\n${detail || ''}</div>`
  );
}

// ═══ API CALLER ═══
async function kineticAPI(method, path, body = null) {
  const url = `${CONFIG.server}/api/v2/odata/${CONFIG.company}/${path}`;
  const creds = btoa(`${CONFIG.user}:${CONFIG.pass}`);
  const headers = {
    'Authorization': `Basic ${creds}`,
    'Content-Type': 'application/json',
    'Accept': 'application/json',
    'x-api-key': CONFIG.apiKey,
  };

  log('info', method, path, body ? JSON.stringify(body).substring(0, 200) : '');

  try {
    const resp = await fetch(url, {
      method,
      headers,
      body: body ? JSON.stringify(body) : null,
    });

    if (!resp.ok) {
      const errText = await resp.text();
      log('err', method, path, `${resp.status}: ${errText.substring(0, 300)}`);
      throw new Error(`${resp.status}: ${errText.substring(0, 200)}`);
    }

    const data = await resp.json();
    const count = data.value ? data.value.length : 1;
    log('ok', method, path, `${count} record(s) returned`);
    return data;
  } catch (err) {
    if (err.message.includes('Failed to fetch') || err.message.includes('NetworkError')) {
      log('err', method, path, 'CORS blocked — use Automation Studio API endpoint instead. See log for details.');
      throw new Error('CORS_BLOCKED');
    }
    throw err;
  }
}

// ═══ CONNECTION TEST ═══
async function testConnection() {
  CONFIG.server = document.getElementById('cfgServer').value.replace(/\/+$/, '');
  CONFIG.company = document.getElementById('cfgCompany').value.trim();
  CONFIG.user = document.getElementById('cfgUser').value.trim();
  CONFIG.pass = document.getElementById('cfgPass').value;
  CONFIG.apiKey = document.getElementById('cfgApiKey').value.trim();

  if (!CONFIG.server || !CONFIG.company) {
    document.getElementById('connStatus').innerHTML = '<span style="color:var(--red)">Server URL and Company ID required</span>';
    return;
  }

  document.getElementById('connStatus').innerHTML = '<div class="spinner"></div> Testing...';
  document.getElementById('btnConnect').disabled = true;

  try {
    const data = await kineticAPI('GET', 'Erp.BO.ResourceGroupSvc/ResourceGroups?$top=1');
    CONNECTED = true;
    const sample = data.value?.[0]?.ResourceGrpID || 'none';

    document.getElementById('connStatus').innerHTML = '<span style="color:var(--green)">✓ Connected! Found resource: ' + sample + '</span>';
    document.getElementById('headerStatus').innerHTML = '<span class="badge" style="background:var(--gs);color:var(--green)"><span class="status-dot" style="background:var(--green)"></span> Connected</span>';
    document.getElementById('headerEnv').textContent = CONFIG.server.replace('https://','').split('.')[0] + ' / ' + CONFIG.company;

    document.getElementById('connResult').innerHTML =
      '<div class="card" style="border-left:3px solid var(--green);max-width:600px;margin-top:8px">' +
      '<div style="font-size:13px;font-weight:700;color:var(--green)">✓ Connected — loading data automatically...</div></div>';

    // Auto-load data after successful connection
    setTimeout(() => loadAllData(), 500);
  } catch (err) {
    CONNECTED = false;
    if (err.message === 'CORS_BLOCKED') {
      document.getElementById('connStatus').innerHTML = '';
      document.getElementById('connResult').innerHTML =
        '<div class="card" style="border-left:3px solid var(--orange);max-width:600px;margin-top:8px">' +
        '<div style="font-size:13px;font-weight:700;color:var(--orange)">⚠ CORS Restriction Detected</div>' +
        '<div style="font-size:12px;color:var(--tmu);margin-top:4px;line-height:1.7">' +
        'The browser blocked the direct API call due to cross-origin security (CORS). This is normal — browsers prevent web pages from calling APIs on other domains.<br><br>' +
        '<strong>Two solutions:</strong><br>' +
        '1. <strong>Automation Studio API Endpoint</strong> (recommended) — create a recipe with "Build an API endpoint" starting point. The dashboard calls Automation Studio, which proxies to Kinetic. No CORS issues.<br>' +
        '2. <strong>Host the dashboard on Kinetic</strong> — deploy it as an App Studio layer. Same-origin, no CORS.<br><br>' +
        'For the Uptive demo, option 1 is fastest. I\'ll load demo data so you can show the dashboard now, and wire the live connection through Automation Studio as the next step.</div>' +
        '<div style="margin-top:10px"><button class="btn btn-teal" onclick="loadDemoData()">Load Demo Data Instead</button></div></div>';
    } else {
      document.getElementById('connStatus').innerHTML = '<span style="color:var(--red)">✗ ' + err.message.substring(0, 100) + '</span>';
    }
  }
  document.getElementById('btnConnect').disabled = false;
}

// ═══ FETCH JOBS ═══
let showAllJobs = true; // Show all jobs by default

async function fetchJobs() {
  document.getElementById('jobsLoading').style.display = 'block';
  try {
    const filter = showAllJobs
      ? "Erp.BO.JobEntrySvc/JobEntries?$filter=JobComplete eq false and JobClosed eq false and ReqDueDate ge 2026-01-01T00:00:00Z&$top=100&$orderby=JobNum desc"
      : "Erp.BO.JobEntrySvc/JobEntries?$filter=JobReleased eq true and JobComplete eq false and ReqDueDate ge 2026-01-01T00:00:00Z&$top=100&$orderby=JobNum desc";

    const data = await kineticAPI('GET', filter);
    LIVE_JOBS = (data.value || []).map(j => ({
      id: j.JobNum, part: j.PartDescription || j.PartNum || j.PartID || '', qty: j.ProdQty || j.OrderQty || 0,
      dueDate: (j.ReqDueDate || j.DueDate || '').split('T')[0],
      priority: j.SchedCode != null ? j.SchedCode : (j.Priority || 'Normal'),
      status: (j.JobHeld || j.OnHold) ? 'On Hold' : j.JobReleased ? 'Released' : j.JobEngineered ? 'Engineered' : 'Open',
      held: j.JobHeld || j.OnHold || false,
      released: j.JobReleased || false,
      engineered: j.JobEngineered || false,
      raw: j
    }));
    if (data.value && data.value[0]) {
      log('info', 'FIELDS', 'JobEntry', 'Available fields: ' + Object.keys(data.value[0]).join(', '));
    }
    renderJobs(LIVE_JOBS);
  } catch (err) {
    if (err.message === 'CORS_BLOCKED') return;
  }
  document.getElementById('jobsLoading').style.display = 'none';
}

// ═══ FETCH RESOURCES + JOB OPERATIONS ═══
let LIVE_JOB_OPERS = [];

async function fetchResources() {
  await fetchResourceLoad();
}

async function fetchResourceLoad() {
  document.getElementById('resLoading').style.display = 'block';
  try {
    // Fetch resource groups with resources
    const resData = await kineticAPI('GET',
      "Erp.BO.ResourceGroupSvc/ResourceGroups?$expand=Resources&$top=50"
    );
    LIVE_RESOURCES = resData.value || [];

    // Use WF_JOBS ops if already loaded, otherwise fetch with job-specific filter
    if (WF_JOBS.length > 0) {
      LIVE_JOB_OPERS = [];
      WF_JOBS.forEach(j => {
        (j.operations || []).filter(op => !op.OpComplete).forEach(op => LIVE_JOB_OPERS.push(op));
      });
      log('info', 'DATA', 'Resource Ops', LIVE_JOB_OPERS.length + ' active ops (from workflow data)');
    } else if (LIVE_JOBS.length > 0) {
      const jobNums = LIVE_JOBS.map(j => `JobNum eq '${j.id}'`).join(' or ');
      const opData = await kineticAPI('GET',
        `Erp.BO.JobEntrySvc/JobOpers?$filter=OpComplete eq false and (${encodeURIComponent(jobNums)})&$top=500`
      );
      LIVE_JOB_OPERS = opData.value || [];
      log('info', 'DATA', 'Resource Ops', LIVE_JOB_OPERS.length + ' active ops (fetched for 2026 jobs)');
    } else {
      LIVE_JOB_OPERS = [];
    }

    if (LIVE_JOB_OPERS.length > 0) {
      log('info', 'FIELDS', 'JobOper', 'Available fields: ' + Object.keys(LIVE_JOB_OPERS[0]).join(', '));
    }

    document.getElementById('resJobCount').textContent = LIVE_JOB_OPERS.length + ' active ops';
    renderResourceLoad(LIVE_RESOURCES, LIVE_JOB_OPERS);
  } catch (err) {
    if (err.message === 'CORS_BLOCKED') return;
    log('err', 'FETCH', 'Resource load error', err.message);
  }
  document.getElementById('resLoading').style.display = 'none';
}

// ═══ RENDER RESOURCE LOAD VIEW ═══
let showScheduledOnly = true; // Default: only show resources with ops

function toggleResFilter() {
  showScheduledOnly = !showScheduledOnly;
  const btn = document.getElementById('btnResFilter');
  btn.textContent = showScheduledOnly ? 'Showing: Scheduled Only' : 'Showing: All Resources';
  btn.className = showScheduledOnly ? 'btn btn-teal' : 'btn btn-outline';
  renderResourceLoad(LIVE_RESOURCES, LIVE_JOB_OPERS);
}

function renderResourceLoad(groups, opers) {
  const grid = document.getElementById('resGrid');
  grid.innerHTML = '';

  // Build lookups
  const opsByGroup = {};
  opers.forEach(op => {
    const grp = op.PrimaryResourceGrpID || op.ResourceGrpID || op.WCCode || '';
    if (grp) { if (!opsByGroup[grp]) opsByGroup[grp] = []; opsByGroup[grp].push(op); }
  });

  const jobLookup = {};
  LIVE_JOBS.forEach(j => { jobLookup[j.id] = j; });

  let visibleCount = 0;

  groups.forEach(g => {
    const grpId = g.ResourceGrpID;
    const isLabor = g.InputType === 'L';
    const resources = (g.Resources || []);
    const grpOps = opsByGroup[grpId] || [];

    if (showScheduledOnly && grpOps.length === 0) return;
    visibleCount++;

    const borderColor = grpOps.length > 0
      ? (isLabor ? 'var(--orange)' : 'var(--teal)')
      : 'var(--bd)';

    // Resources list
    let resListHTML = resources.map(r => {
      const dot = (r.Inactive || r.InActive) ? 'var(--red)' : 'var(--green)';
      return `<span style="display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:4px;background:var(--sa);border:1px solid var(--bl);font-size:11px;margin:2px">
        <span class="status-dot" style="background:${dot}"></span>
        <span style="font-weight:600">${r.Description || r.ResourceID}</span>
        <span class="mono" style="font-size:9px;color:var(--tdi)">${r.ResourceID}</span>
      </span>`;
    }).join('');

    // Jobs list for this group
    let jobsHTML = '';
    if (grpOps.length > 0) {
      jobsHTML = grpOps.map(op => {
        const job = jobLookup[op.JobNum] || {};
        const priLabel = PRI_LABELS[job.priority] || job.priority || '';
        const priColor = PRI_COLORS[priLabel] || 'var(--sa);color:var(--tmu)';
        const dl = job.dueDate ? Math.ceil((new Date(job.dueDate) - new Date()) / 86400000) : 99;
        const dlColor = dl <= 3 ? 'var(--red)' : dl <= 7 ? 'var(--orange)' : dl <= 14 ? 'var(--yellow)' : 'var(--tdi)';
        const opCode = op.OpCode || '';
        const estHrs = (op.EstProdHours || 0).toFixed(1);
        return `<div style="display:flex;align-items:center;gap:6px;padding:6px 8px;border-bottom:1px solid var(--bl);font-size:11px;cursor:pointer" onclick="selectJob('${op.JobNum}')">
          <span class="mono" style="font-weight:600;color:var(--teal);min-width:68px">${op.JobNum}</span>
          <span style="flex:1;color:var(--tx);font-weight:500">${job.part || ''}</span>
          <span class="mono" style="font-size:10px;color:var(--tmu)">${opCode}</span>
          <span class="mono" style="font-size:10px;color:var(--tmu)">${estHrs}h</span>
          <span class="badge" style="background:${priColor};font-size:9px;padding:1px 6px">${priLabel}</span>
          <span style="font-size:10px;font-weight:700;color:${dlColor};min-width:30px;text-align:right">${dl}d</span>
        </div>`;
      }).join('');
    } else {
      jobsHTML = '<div style="padding:8px;font-size:12px;color:var(--tdi);font-style:italic">No active operations</div>';
    }

    grid.insertAdjacentHTML('beforeend', `
      <div class="card" style="border-top:3px solid ${borderColor}">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <div>
            <div style="font-size:15px;font-weight:700">${g.Description || grpId}</div>
            <div style="font-size:11px;color:var(--tmu)">${grpId} · ${resources.length} resources · ${grpOps.length} active ops</div>
          </div>
          <span class="badge" style="background:${isLabor?'var(--os);color:var(--orange)':'var(--ts);color:var(--teal)'}">${isLabor?'👷 Labor':'⚙️ Machine'}</span>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:2px;margin-bottom:8px">${resListHTML}</div>
        <div style="background:var(--sa);border-radius:6px;border:1px solid var(--bl);overflow:hidden">
          ${jobsHTML}
        </div>
      </div>
    `);
  });

  if (visibleCount === 0) {
    grid.innerHTML = showScheduledOnly
      ? '<div class="card" style="text-align:center;color:var(--tmu);padding:30px">No resources with scheduled operations. Switch to "All Resources" to see everything.</div>'
      : '<div class="card" style="text-align:center;color:var(--tmu);padding:30px">No resource groups found. Connect and pull data first.</div>';
  }

  document.getElementById('resJobCount').textContent = opers.length + ' active ops';
}

// ═══ JOB WORKFLOW ═══
let WF_JOBS = []; // Jobs with their operations

async function fetchWorkflow() {
  document.getElementById('wfLoading').style.display = 'block';
  try {
    // Use existing LIVE_JOBS if available, otherwise fetch
    if (LIVE_JOBS.length === 0) await fetchJobs();
    if (LIVE_JOBS.length === 0) {
      log('err', 'WORKFLOW', 'No jobs', 'No 2026 jobs found');
      document.getElementById('wfLoading').style.display = 'none';
      return;
    }

    // Build OData filter for only our 2026 job numbers
    const jobNums = LIVE_JOBS.map(j => `JobNum eq '${j.id}'`).join(' or ');
    const filter = `(${jobNums})`;
    log('info', 'WORKFLOW', 'Fetching ops for', LIVE_JOBS.length + ' jobs');

    const opData = await kineticAPI('GET',
      `Erp.BO.JobEntrySvc/JobOpers?$filter=${encodeURIComponent(filter)}&$top=500`
    );
    const allOps = opData.value || [];
    log('info', 'WORKFLOW', 'Operations returned', allOps.length + ' ops for 2026 jobs');

    // Group operations by job
    const opsByJob = {};
    allOps.forEach(op => {
      if (!opsByJob[op.JobNum]) opsByJob[op.JobNum] = [];
      opsByJob[op.JobNum].push(op);
    });

    // Sort operations within each job by sequence
    Object.keys(opsByJob).forEach(jn => {
      opsByJob[jn].sort((a, b) => (a.OprSeq || 0) - (b.OprSeq || 0));
    });

    // Build WF_JOBS with operations attached
    WF_JOBS = LIVE_JOBS.filter(j => opsByJob[j.id] && opsByJob[j.id].length > 0).map(j => ({
      ...j,
      operations: opsByJob[j.id] || []
    }));

    log('info', 'WORKFLOW', 'Jobs with ops', WF_JOBS.length + ' jobs loaded with operations');
    if (allOps.length > 0) {
      const sample = allOps[0];
      log('info', 'DEBUG', 'Sample UPT Op',
        `JobNum=${sample.JobNum} OprSeq=${sample.OprSeq} OpCode=${sample.OpCode} ` +
        `PrimaryResourceGrpID="${sample.PrimaryResourceGrpID}" EstProdHours=${sample.EstProdHours} ` +
        `ActProdHours=${sample.ActProdHours} OpComplete=${sample.OpComplete}`
      );
    }

    renderWorkflow();
  } catch (err) {
    log('err', 'WORKFLOW', 'Error', err.message);
  }
  document.getElementById('wfLoading').style.display = 'none';
}

let activeWfFilter = '';

function setWfFilter(val) {
  activeWfFilter = val;
  document.getElementById('wfFilter').value = val.startsWith('__') ? '' : val;
  // Update button styles
  document.querySelectorAll('#tab-workflow .btn').forEach(b => {
    if (b.onclick && b.textContent !== '↻ Refresh') {
      b.className = 'btn btn-outline';
      b.style.fontSize = '10px';
      b.style.padding = '4px 10px';
    }
  });
  if (val === '') document.getElementById('wfBtnAll').className = 'btn btn-teal';
  renderWorkflow();
}

function renderWorkflow() {
  const grid = document.getElementById('wfGrid');
  grid.innerHTML = '';
  const filterText = (document.getElementById('wfFilter')?.value || '').toLowerCase();
  const smartFilter = activeWfFilter;
  const today = new Date();

  const filtered = WF_JOBS.filter(j => {
    // Smart filters
    if (smartFilter === '__critical') {
      const dl = j.dueDate ? Math.ceil((new Date(j.dueDate) - today) / 86400000) : 99;
      return dl <= 7;
    }
    if (smartFilter === '__late') {
      // Check if estimated finish is past due date
      let remainingHrs = 0;
      j.operations.forEach(op => { if (!op.OpComplete) remainingHrs += (op.EstProdHours || 0) + (op.EstSetHours || 0); });
      const workDays = Math.ceil(remainingHrs / 8);
      const estFinish = new Date(today); estFinish.setDate(estFinish.getDate() + workDays);
      const schedDue = j.raw?.DueDate ? new Date(j.raw.DueDate) : null;
      const due = j.dueDate ? new Date(j.dueDate) : null;
      const finishDate = (schedDue && schedDue.getFullYear() > 2000) ? schedDue : estFinish;
      return due && finishDate > due;
    }
    if (smartFilter === '__inprogress') {
      return j.operations.some(op => op.OpComplete) && j.operations.some(op => !op.OpComplete);
    }
    // Text filter
    if (!filterText) return true;
    return j.id.toLowerCase().includes(filterText)
      || (j.part || '').toLowerCase().includes(filterText)
      || (j.raw?.CommentText || '').toLowerCase().includes(filterText)
      || (j.raw?.PartNum || '').toLowerCase().includes(filterText);
  });

  document.getElementById('wfCount').textContent = filtered.length + ' jobs';

  if (filtered.length === 0) {
    grid.innerHTML = '<div class="card" style="text-align:center;color:var(--tmu);padding:30px">No jobs with operations found. Pull data first.</div>';
    return;
  }

  // Sort: nearest due date first
  filtered.sort((a, b) => {
    const da = a.dueDate ? new Date(a.dueDate) : new Date('2099-01-01');
    const db = b.dueDate ? new Date(b.dueDate) : new Date('2099-01-01');
    return da - db;
  });

  filtered.forEach(j => {
    const today = new Date();
    const dl = j.dueDate ? Math.ceil((new Date(j.dueDate) - today) / 86400000) : 99;
    const dlColor = dl <= 3 ? 'var(--red)' : dl <= 7 ? 'var(--orange)' : dl <= 14 ? 'var(--yellow)' : 'var(--green)';
    const priLabel = PRI_LABELS[j.priority] || j.priority || 'Normal';
    const priColor = PRI_COLORS[priLabel] || 'var(--sa);color:var(--tmu)';
    const comment = j.raw?.CommentText || '';

    // ─── Time-based progress ───
    const totalOps = j.operations.length;
    const completeOps = j.operations.filter(op => op.OpComplete).length;

    // Calculate total estimated hours and actual hours across all ops
    let totalEstHrs = 0, totalActHrs = 0, remainingHrs = 0;
    j.operations.forEach(op => {
      const est = (op.EstProdHours || 0) + (op.EstSetHours || 0);
      const act = (op.ActProdHours || 0) + (op.ActSetupHours || 0);
      totalEstHrs += est;
      totalActHrs += act;
      if (!op.OpComplete) remainingHrs += est;
    });

    // Time-based percentage (if no actual hours, fall back to op count)
    const pct = totalEstHrs > 0
      ? Math.min(100, Math.round(((totalEstHrs - remainingHrs) / totalEstHrs) * 100))
      : (totalOps > 0 ? Math.round((completeOps / totalOps) * 100) : 0);

    // ─── Dates ───
    const reqDueDate = j.dueDate || '';
    const schedDueDate = (j.raw?.DueDate || '').split('T')[0];
    const schedStartDate = (j.raw?.StartDate || '').split('T')[0];
    const shipDate = schedDueDate || reqDueDate; // Scheduled due = ship target

    // ─── Estimated finish date ───
    let estFinishDate = '';
    let estFinishDays = null;
    if (schedDueDate && schedDueDate !== '0001-01-01') {
      // Use scheduled due date from Kinetic scheduler
      estFinishDate = schedDueDate;
      estFinishDays = Math.ceil((new Date(schedDueDate) - today) / 86400000);
    } else if (remainingHrs > 0) {
      // Estimate: remaining hours ÷ 8 hrs/day = working days from now
      const workDaysRemaining = Math.ceil(remainingHrs / 8);
      const estFinish = new Date(today);
      estFinish.setDate(estFinish.getDate() + workDaysRemaining);
      estFinishDate = estFinish.toISOString().split('T')[0];
      estFinishDays = workDaysRemaining;
    }

    // Is the estimated finish after the due date?
    const isLate = estFinishDate && reqDueDate && new Date(estFinishDate) > new Date(reqDueDate);

    // Find current operation
    const currentOp = j.operations.find(op => !op.OpComplete);
    const currentSeq = currentOp ? currentOp.OprSeq : null;

    // Build operation workflow nodes
    const opsHTML = j.operations.map((op, idx) => {
      const isComplete = op.OpComplete || false;
      const isCurrent = op.OprSeq === currentSeq;
      const isPending = !isComplete && !isCurrent;

      const estHrs = (op.EstProdHours || 0) + (op.EstSetHours || 0);
      const actHrs = (op.ActProdHours || 0) + (op.ActSetupHours || 0);
      const timeDiff = actHrs - estHrs;
      const isOverTime = isComplete && timeDiff > 0.1;

      let nodeBg, nodeBorder, nodeTextColor, statusIcon;
      if (isComplete) {
        nodeBg = isOverTime ? 'var(--rs)' : 'var(--gs)';
        nodeBorder = isOverTime ? 'var(--red)' : 'var(--green)';
        nodeTextColor = isOverTime ? 'var(--red)' : 'var(--green)';
        statusIcon = isOverTime ? '⚠' : '✓';
      } else if (isCurrent) {
        nodeBg = 'var(--ts)';
        nodeBorder = 'var(--teal)';
        nodeTextColor = 'var(--teal)';
        statusIcon = '▶';
      } else {
        nodeBg = 'var(--sa)';
        nodeBorder = 'var(--bd)';
        nodeTextColor = 'var(--tdi)';
        statusIcon = '';
      }

      const resGrp = op.PrimaryResourceGrpID || op.ResourceGrpID || op.WCCode || '';
      const opCode = op.OpCode || '';

      let timeHTML = '';
      if (isComplete && actHrs > 0) {
        const sign = timeDiff > 0 ? '+' : '';
        const timeColor = timeDiff > 0 ? 'var(--red)' : 'var(--green)';
        timeHTML = `<div style="font-size:9px;font-weight:700;color:${timeColor}">${sign}${timeDiff.toFixed(1)}h</div>`;
      } else if (isCurrent && estHrs > 0) {
        timeHTML = `<div style="font-size:9px;color:var(--tmu)">${estHrs.toFixed(1)}h est</div>`;
      } else if (isPending && estHrs > 0) {
        timeHTML = `<div style="font-size:9px;color:var(--tdi)">${estHrs.toFixed(1)}h</div>`;
      }

      const arrow = idx < j.operations.length - 1
        ? `<div style="display:flex;align-items:center;color:var(--bd);font-size:14px;margin:0 2px">→</div>`
        : '';

      return `<div style="display:flex;align-items:center">
        <div style="min-width:72px;padding:6px 8px;border-radius:6px;background:${nodeBg};border:2px solid ${nodeBorder};text-align:center">
          <div style="font-size:9px;font-weight:700;color:${nodeTextColor};margin-bottom:1px">${statusIcon} ${opCode}</div>
          <div style="font-size:9px;color:${nodeTextColor}">${resGrp}</div>
          ${timeHTML}
        </div>
        ${arrow}
      </div>`;
    }).join('');

    const progressColor = isLate ? 'var(--red)' : dl <= 3 ? 'var(--red)' : dl <= 7 ? 'var(--orange)' : 'var(--teal)';
    const cardBorder = isLate ? 'var(--red)' : dl <= 3 ? 'var(--red)' : dl <= 7 ? 'var(--orange)' : dl <= 14 ? 'var(--yellow)' : 'var(--teal)';

    // Format dates helper
    const fmtDate = d => d && d !== '0001-01-01' ? d : '—';
    const estFinishColor = isLate ? 'var(--red)' : 'var(--green)';

    grid.insertAdjacentHTML('beforeend', `
      <div class="card" style="border-left:4px solid ${cardBorder};margin-bottom:12px;cursor:pointer" onclick="selectJob('${j.id}')">
        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:6px">
          <div>
            <div style="display:flex;align-items:center;gap:8px">
              <span class="mono" style="font-size:15px;font-weight:700;color:var(--teal)">${j.id}</span>
              <span style="font-size:14px;font-weight:600">${j.part || ''}</span>
              <span class="badge" style="background:${priColor};font-size:10px">${priLabel}</span>
            </div>
            ${comment ? `<div style="font-size:11px;color:var(--tmu);margin-top:2px;font-style:italic">${comment}</div>` : ''}
          </div>
          <div style="text-align:right">
            <div style="font-size:20px;font-weight:700;color:${dlColor};line-height:1">${dl}d</div>
            <div style="font-size:9px;color:var(--tmu)">to due date</div>
          </div>
        </div>

        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
          <div style="font-size:12px;font-weight:700;color:${progressColor};min-width:50px">${pct}%</div>
          <div style="flex:1;height:8px;background:var(--bl);border-radius:4px;overflow:hidden">
            <div style="width:${pct}%;height:100%;background:${progressColor};border-radius:4px;transition:width .3s"></div>
          </div>
          <div style="font-size:10px;color:var(--tmu)">${totalActHrs.toFixed(1)}h / ${totalEstHrs.toFixed(1)}h</div>
          <div style="font-size:10px;color:var(--tmu)">${completeOps}/${totalOps} ops</div>
        </div>

        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:8px;padding:8px;background:var(--sa);border-radius:6px">
          <div style="text-align:center">
            <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase;letter-spacing:.5px">Due Date</div>
            <div class="mono" style="font-size:12px;font-weight:700;color:${dlColor}">${fmtDate(reqDueDate)}</div>
          </div>
          <div style="text-align:center">
            <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase;letter-spacing:.5px">Est. Finish</div>
            <div class="mono" style="font-size:12px;font-weight:700;color:${estFinishColor}">${fmtDate(estFinishDate)}${isLate ? ' ⚠' : ''}</div>
          </div>
          <div style="text-align:center">
            <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase;letter-spacing:.5px">Ship Target</div>
            <div class="mono" style="font-size:12px;font-weight:700;color:var(--tx)">${fmtDate(shipDate)}</div>
          </div>
          <div style="text-align:center">
            <div style="font-size:9px;font-weight:600;color:var(--tmu);text-transform:uppercase;letter-spacing:.5px">Remaining</div>
            <div style="font-size:12px;font-weight:700;color:${remainingHrs > 0 ? 'var(--tmu)' : 'var(--green)'}">${remainingHrs.toFixed(1)}h</div>
          </div>
        </div>

        <div style="display:flex;align-items:center;overflow-x:auto;padding:4px 0;gap:0">
          ${opsHTML}
        </div>

        <div style="display:flex;justify-content:between;gap:12px;margin-top:6px">
          <span class="mono" style="font-size:10px;color:var(--tdi)">Qty: ${j.qty}</span>
          ${isLate ? '<span style="font-size:10px;font-weight:700;color:var(--red)">⚠ ESTIMATED LATE — Est. finish is past due date</span>' : ''}
        </div>
      </div>
    `);
  });
}

// ═══ LOAD ALL ═══
async function loadAllData() {
  if (!CONFIG.server) {
    CONFIG.server = document.getElementById('cfgServer').value.replace(/\/+$/, '');
    CONFIG.company = document.getElementById('cfgCompany').value.trim();
    CONFIG.user = document.getElementById('cfgUser').value.trim();
    CONFIG.pass = document.getElementById('cfgPass').value;
    CONFIG.apiKey = document.getElementById('cfgApiKey').value.trim();
  }
  if (!CONFIG.server || !CONFIG.company) {
    alert('Enter Server URL and Company ID on the Connect tab first');
    return;
  }
  CONNECTED = true;
  await fetchJobs();
  await fetchWorkflow();
  await fetchResourceLoad();
  runAIEngine();
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tc').forEach(t => t.classList.remove('active'));
  document.querySelector('[data-tab="jobs"]').classList.add('active');
  document.getElementById('tab-jobs').classList.add('active');
}

// ═══ RENDER JOBS ═══
const PRI_LABELS = {0:'Normal','HIGH':'High','IMMED':'Immediate','LOW':'Low','NORMAL':'Normal','VHIGH':'Very High','VLOW':'Very Low'};
const PRI_COLORS = {'Very High':'var(--rs);color:var(--red)','High':'var(--os);color:var(--orange)','Immediate':'var(--rs);color:var(--red)','Normal':'var(--ts);color:var(--teal)','Low':'var(--sa);color:var(--tmu)','Very Low':'var(--sa);color:var(--tmu)'};

function renderJobs(jobs) {
  const tb = document.getElementById('jobsTable');
  tb.innerHTML = '';
  document.getElementById('jobCount').textContent = jobs.length + ' jobs';
  document.getElementById('jobsEmpty').style.display = jobs.length === 0 ? 'block' : 'none';

  jobs.forEach(j => {
    const dl = j.dueDate ? Math.ceil((new Date(j.dueDate) - new Date()) / 86400000) : 99;
    const stColors = {'On Hold':'var(--os);color:var(--orange)','Released':'var(--gs);color:var(--green)','Engineered':'var(--ts);color:var(--teal)','Open':'var(--sa);color:var(--tmu)','In Progress':'var(--gs);color:var(--green)'};
    const stColor = stColors[j.status] || 'var(--sa);color:var(--tmu)';
    const priLabel = typeof j.priority === 'number' ? (PRI_LABELS[j.priority] || String(j.priority)) : j.priority;
    const priColor = PRI_COLORS[priLabel] || 'var(--sa);color:var(--tmu)';

    tb.insertAdjacentHTML('beforeend', `
      <tr onclick="selectJob('${j.id}')" style="cursor:pointer" data-job="${j.id}" data-part="${(j.part||'').toLowerCase()}" data-status="${j.status.toLowerCase()}" data-pri="${priLabel.toLowerCase()}">
        <td class="mono" style="font-weight:600;color:var(--teal)">${j.id}</td>
        <td style="font-weight:600">${j.part || '—'}</td>
        <td class="mono">${j.qty}</td>
        <td><span class="mono">${j.dueDate}</span> <span style="font-size:10px;font-weight:600;margin-left:4px;color:${dl<=5?'var(--red)':dl<=10?'var(--yellow)':'var(--tdi)'}">${dl}d</span></td>
        <td><span class="badge" style="background:${priColor}">${priLabel}</span></td>
        <td><span class="badge" style="background:${stColor}">${j.status}</span></td>
        <td>
          <button class="btn btn-outline" style="font-size:10px;padding:3px 8px" onclick="event.stopPropagation();quickAction('${j.id}','priorityHigh')">⬆ Expedite</button>
          <button class="btn btn-outline" style="font-size:10px;padding:3px 8px" onclick="event.stopPropagation();quickAction('${j.id}','${j.held?'release':'hold'}')">${j.held?'Release':'Hold'}</button>
          <button class="btn btn-outline" style="font-size:10px;padding:3px 8px" onclick="event.stopPropagation();quickAction('${j.id}','scheduleForward')">▶ Sched</button>
        </td>
      </tr>
    `);
  });
}

function selectJob(jobNum) {
  document.getElementById('actJob').value = jobNum;
  document.querySelectorAll('#jobsTable tr').forEach(r => r.style.background = '');
  const row = document.querySelector('#jobsTable tr[data-job="'+jobNum+'"]');
  if (row) row.style.background = 'var(--tl)';
}

function filterJobs() {
  const q = document.getElementById('jobFilter').value.toLowerCase().trim();
  const rows = document.querySelectorAll('#jobsTable tr');
  let visible = 0;
  rows.forEach(r => {
    const match = !q || (r.dataset.job||'').includes(q) || (r.dataset.part||'').includes(q) || (r.dataset.status||'').includes(q) || (r.dataset.pri||'').includes(q);
    r.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  document.getElementById('jobCount').textContent = visible + ' of ' + rows.length + ' jobs';
}

function toggleJobScope() {
  showAllJobs = !showAllJobs;
  const btn = document.getElementById('btnJobScope');
  btn.textContent = showAllJobs ? 'Showing: All 2026 Jobs' : 'Showing: Released 2026 Only';
  btn.className = showAllJobs ? 'btn btn-teal' : 'btn btn-outline';
  fetchJobs();
}

// ═══ AI ENGINE ═══
function runAIEngine() {
  const list = document.getElementById('recsList');
  list.innerHTML = '';
  const recs = [];
  const today = new Date();

  LIVE_JOBS.forEach(j => {
    if (!j.dueDate) return;
    const dl = Math.ceil((new Date(j.dueDate) - today) / 86400000);
    if (dl <= 7 && dl >= 0) {
      recs.push({
        sev: dl <= 3 ? 'critical' : 'high', cat: 'Due Date Risk',
        title: `${j.id} — ${j.part} due in ${dl} days`,
        body: `Job ${j.id} is due ${j.dueDate} (${dl} calendar days). Priority is currently ${j.priority}. ${dl <= 3 ? 'This job needs immediate attention.' : 'Review capacity to ensure on-time delivery.'}`,
        action: `Expedite ${j.id}`, jobId: j.id
      });
    }
    if (j.status === 'On Hold') {
      recs.push({
        sev: 'info', cat: 'Held Job',
        title: `${j.id} — ${j.part} is on hold`,
        body: `This job is currently held. If the hold is resolved, release it to free capacity in the schedule.`,
        action: `Release ${j.id}`, jobId: j.id
      });
    }
  });

  LIVE_RESOURCES.forEach(g => {
    const sisterPairs = (g.Resources || []).filter(r => r.LinkedResourceID || r.LinkedResource);
    if (sisterPairs.length > 0) {
      recs.push({
        sev: 'info', cat: 'Sister Machine',
        title: `${g.Description || g.ResourceGrpID} has sister machine pair`,
        body: `${sisterPairs.map(r => r.ResourceID + ' ↔ ' + (r.LinkedResourceID||r.LinkedResource)).join(', ')}. Verify load is balanced.`,
        action: null
      });
    }
    if (g.InputType === 'L') {
      const headcount = (g.Resources || []).reduce((s, r) => s + (r.NumSimultaneous || r.NumberOfMachines || 1), 0);
      recs.push({
        sev: 'medium', cat: 'Labor Constraint',
        title: `${g.Description} is labor-constrained (${headcount} workers)`,
        body: `This work center schedules against headcount, not machine hours. Monitor utilization closely — any upstream delay cascades through this bottleneck.`,
        action: null
      });
    }
  });

  document.getElementById('recCount').textContent = recs.length + ' recommendations';

  if (recs.length === 0) {
    list.innerHTML = '<div class="card" style="text-align:center;color:var(--tmu);padding:30px">Pull data from Kinetic first to generate recommendations.</div>';
    return;
  }

  recs.sort((a, b) => {
    const o = { critical: 0, high: 1, medium: 2, info: 3 };
    return (o[a.sev] || 9) - (o[b.sev] || 9);
  });

  recs.forEach(r => {
    const sevBadge = { critical: 'background:var(--rs);color:var(--red)', high: 'background:var(--os);color:var(--orange)', medium: 'background:var(--ys);color:var(--yellow)', info: 'background:var(--ts);color:var(--teal)' }[r.sev];
    const sevIcon = { critical: '●', high: '▲', medium: '◆', info: '○' }[r.sev];
    const borderColors = { critical: 'var(--red)', high: 'var(--orange)', medium: 'var(--yellow)', info: 'var(--teal)' };
    const actionBtn = r.action && r.jobId
      ? `<button class="btn btn-teal" style="font-size:11px;padding:5px 12px;margin-top:auto;width:100%" onclick="event.stopPropagation();quickAction('${r.jobId}','priorityHigh')">⬆ ${r.action}</button>`
      : '';
    const clickHandler = r.jobId ? ` onclick="showJobDetail('${r.jobId}')"` : '';
    list.insertAdjacentHTML('beforeend', `
      <div${clickHandler} style="background:var(--sf);border:1px solid var(--bd);border-top:3px solid ${borderColors[r.sev]};border-radius:6px;padding:14px;display:flex;flex-direction:column;min-height:160px;${r.jobId?'cursor:pointer':''}">
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;flex-wrap:wrap">
          <span class="badge" style="${sevBadge};font-size:10px">${sevIcon} ${r.sev.toUpperCase()}</span>
          <span class="badge" style="background:var(--sa);color:var(--tmu);font-size:10px;border:1px solid var(--bd)">${r.cat}</span>
        </div>
        <div style="font-size:13px;font-weight:700;margin-bottom:6px;line-height:1.4">${r.title}</div>
        <div style="font-size:12px;color:var(--tmu);line-height:1.6;flex:1">${r.body}</div>
        ${actionBtn}
      </div>
    `);
  });
}

// ═══ ACTIONS ═══
async function quickAction(jobNum, action) {
  document.getElementById('actJob').value = jobNum;
  await runAction(action);
}

async function runAction(action) {
  const jobNum = document.getElementById('actJob').value.trim();
  const result = document.getElementById('actionResult');

  if (!jobNum) {
    result.innerHTML = '<div class="card" style="border-left:3px solid var(--red)"><span style="color:var(--red);font-weight:600">Enter a job number above first</span></div>';
    return;
  }
  if (!CONNECTED) {
    result.innerHTML = '<div class="card" style="border-left:3px solid var(--red)"><span style="color:var(--red);font-weight:600">Connect to Kinetic first</span></div>';
    return;
  }

  const labels = {
    scheduleForward:'Schedule Forward', scheduleBackward:'Schedule Backward',
    unschedule:'Remove from Schedule', priorityVeryHigh:'Priority → Very High',
    priorityHigh:'Priority → High', priorityImmediate:'Priority → Immediate (Forward Schedule)',
    priorityNormal:'Priority → Normal', priorityLow:'Priority → Low',
    hold:'Put on Hold', release:'Release from Hold',
  };

  result.innerHTML = `<div class="card" style="text-align:center;padding:20px"><div class="spinner"></div><div style="margin-top:8px;color:var(--tmu)">Pushing "${labels[action] || action}" to Kinetic for job ${jobNum}...</div></div>`;

  try {
    let msg = '';
    let detail = '';

    // Helper: Get job Company for PATCH URL
    async function getJobCompany() {
      const data = await kineticAPI('GET', `Erp.BO.JobEntrySvc/JobEntries?$filter=JobNum eq '${jobNum}'&$top=1`);
      if (!data.value?.length) throw new Error('Job not found');
      log('info', 'DEBUG', 'Job SchedCode', data.value[0].SchedCode || 'not set');
      return data.value[0];
    }

    // Helper: Write to Kinetic via Automation Studio webhook
    const WEBHOOKS = {
      updatePriority: 'https://webhooks.workato.com/webhooks/rest/6a549569-6fe2-4070-8319-a420db92eddc/update-job',
      // Add more webhook URLs here as you create recipes:
      // holdJob: 'https://webhooks.workato.com/webhooks/rest/...',
      // scheduleJob: 'https://webhooks.workato.com/webhooks/rest/...',
    };

    async function callWebhook(webhookUrl, payload) {
      log('info', 'WEBHOOK', 'POST', JSON.stringify(payload));
      const resp = await fetch(webhookUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const text = await resp.text();
      if (!resp.ok) {
        log('err', 'WEBHOOK', resp.status + '', text.substring(0, 200));
        throw new Error('Webhook failed: ' + text.substring(0, 200));
      }
      log('ok', 'WEBHOOK', 'Success', text.substring(0, 200));
      return text;
    }

    // For fields that go through Automation Studio
    async function patchJobField(fieldName, fieldValue) {
      const before = await kineticAPI('GET', `Erp.BO.JobEntrySvc/JobEntries?$filter=JobNum eq '${jobNum}'&$top=1`);
      const oldVal = before.value?.[0]?.[fieldName];
      log('info', 'DEBUG', `BEFORE: ${fieldName}`, JSON.stringify(oldVal));

      await callWebhook(WEBHOOKS.updatePriority, { jobNum: jobNum, newPriority: fieldValue });

      // Give Kinetic a moment to process, then verify
      await new Promise(r => setTimeout(r, 1500));
      const after = await kineticAPI('GET', `Erp.BO.JobEntrySvc/JobEntries?$filter=JobNum eq '${jobNum}'&$top=1`);
      const newVal = after.value?.[0]?.[fieldName];
      log('info', 'DEBUG', `AFTER: ${fieldName}`, JSON.stringify(newVal));

      if (JSON.stringify(newVal) !== JSON.stringify(oldVal)) {
        log('ok', 'VERIFY', 'VALUE CHANGED', `${fieldName}: ${JSON.stringify(oldVal)} → ${JSON.stringify(newVal)}`);
      } else {
        log('err', 'VERIFY', 'May not have changed', `${fieldName} still = ${JSON.stringify(oldVal)}`);
      }
      return { [fieldName]: oldVal };
    }

    if (action === 'scheduleForward') {
      await callWebhook(WEBHOOKS.updatePriority, { jobNum: jobNum, newPriority: 'IMMED' });
      msg = 'Schedule Forward — Priority set to Immediate';
      detail = 'SchedCode changed to IMMED (Priority Factor 1,000). Kinetic auto-triggers forward scheduling from the start date.';

    } else if (action === 'scheduleBackward') {
      await callWebhook(WEBHOOKS.updatePriority, { jobNum: jobNum, newPriority: 'NORMAL' });
      msg = 'Schedule Backward — Priority set to Normal';
      detail = 'SchedCode changed to NORMAL with Schedule Backwards enabled. Kinetic schedules backward from the due date.';

    } else if (action === 'unschedule') {
      await callWebhook(WEBHOOKS.updatePriority, { jobNum: jobNum, newPriority: 'LOW' });
      msg = 'Deprioritized — Priority set to Low';
      detail = 'SchedCode changed to LOW (Priority Factor 10). Job moves to bottom of scheduling queue.';

    } else if (action.startsWith('priority')) {
      const priMap = {
        priorityVeryHigh: 'VHIGH', priorityHigh: 'HIGH',
        priorityImmediate: 'IMMED',
        priorityNormal: 'NORMAL', priorityLow: 'LOW',
      };
      const priLabels = {VHIGH:'Very High',HIGH:'High',IMMED:'Immediate',NORMAL:'Normal',LOW:'Low',VLOW:'Very Low'};
      const newPri = priMap[action] || 'HIGH';
      const result = await patchJobField('SchedCode', newPri);
      msg = `Priority → ${priLabels[newPri] || newPri}`;
      detail = newPri === 'IMMED'
        ? 'Kinetic will auto-trigger forward scheduling for this job.'
        : 'Priority updated in Kinetic. Reschedule to see the change take effect.';

    } else if (action === 'hold') {
      await patchJobField('JobHeld', true);
      msg = 'Job Placed on Hold';
      detail = 'Scheduling blocks released. Capacity freed for other jobs. Materials remain allocated.';

    } else if (action === 'release') {
      await patchJobField('JobHeld', false);
      msg = 'Job Released from Hold';
      detail = 'Job is eligible for scheduling again. Use Schedule Forward or Backward to place it back on resources.';
    }

    result.innerHTML = `<div class="card" style="border-left:3px solid var(--green);margin-top:8px">
      <div style="font-size:13px;font-weight:700;color:var(--green)">✓ ${msg}</div>
      <div style="font-size:12px;color:var(--tmu);margin-top:4px">${detail}</div>
      <div style="font-size:11px;color:var(--tdi);margin-top:6px">Job ${jobNum} updated in Kinetic. Open Job Entry to verify, or refresh the Jobs tab.</div>
    </div>`;

    setTimeout(() => fetchJobs(), 1500);
  } catch (err) {
    if (err.message !== 'CORS_BLOCKED') {
      result.innerHTML = `<div class="card" style="border-left:3px solid var(--red)"><span style="color:var(--red);font-weight:600">Error: ${err.message.substring(0, 200)}</span></div>`;
    }
  }
}

